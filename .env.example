# ============================================================
# LegalBridge 環境変数サンプル
# 2026-04-14 時点の「Backlog はステータス管理 + 任意補足欄」前提
# ============================================================

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-x-xxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxx
SLACK_LEGAL_CHANNEL=C0000000000
APPROVER_SLACK_ID=U0000000000
STAMP_OPERATOR_SLACK_ID=U0000000000

# --- Backlog ---
BACKLOG_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BACKLOG_SPACE=arclight
BACKLOG_PROJECT_KEY=LEGAL
BACKLOG_POLLING_INTERVAL_SEC=30

# 課題タイプ名
BACKLOG_ISSUE_TYPE_NDA=NDA
BACKLOG_ISSUE_TYPE_OUTSOURCING=業務委託基本契約
BACKLOG_ISSUE_TYPE_LICENSE=ライセンス契約
BACKLOG_ISSUE_TYPE_LICENSE_SCHEDULE=個別利用許諾条件
BACKLOG_ISSUE_TYPE_IP_OVERSEAS_MASTER=海外IP契約（基本契約）
BACKLOG_ISSUE_TYPE_IP_OVERSEAS_AMENDMENT=海外IP契約（変更合意）
BACKLOG_ISSUE_TYPE_SALES_BUYER=売買契約（当社買手）
BACKLOG_ISSUE_TYPE_SALES_SELLER_STANDARD=売買契約（当社売手・標準）
BACKLOG_ISSUE_TYPE_SALES_SELLER_CREDIT=売買契約（当社売手・保証金掛け売り）
BACKLOG_ISSUE_TYPE_PURCHASE_ORDER=発注書
BACKLOG_ISSUE_TYPE_PLANNING_ORDER=企画発注書
BACKLOG_ISSUE_TYPE_PUBLISHING_ORDER=出版発注書
BACKLOG_ISSUE_TYPE_DELIVERY=納品リクエスト
BACKLOG_ISSUE_TYPE_MFG=製造案件
BACKLOG_ISSUE_TYPE_ROYALTY_SALES=売上報告案件
BACKLOG_ISSUE_TYPE_LEGAL_CONSULTATION=法務相談

# Backlog カスタム属性ID
# すべて任意項目です。設定したものだけ Backlog へ書き戻します。
BACKLOG_FIELD_COUNTERPARTY=000000
BACKLOG_FIELD_DEADLINE=000000
BACKLOG_FIELD_REMARKS=000000
BACKLOG_FIELD_CONTRACT_NO=000000
BACKLOG_FIELD_CONTRACT_DATE=000000
BACKLOG_FIELD_CONTRACT_PERIOD=000000
BACKLOG_FIELD_PROJECT_TITLE=000000
BACKLOG_FIELD_LICENSE_KEY=000000
BACKLOG_FIELD_LICENSE_START=000000
BACKLOG_FIELD_PARENT_ISSUE_KEY=000000
BACKLOG_FIELD_ITEM_NO=000000
BACKLOG_FIELD_DELIVERY_NOTE=000000
BACKLOG_FIELD_DELIVERED_AMOUNT=000000
BACKLOG_FIELD_FINAL_DEADLINE=000000
BACKLOG_FIELD_INSPECTION_DATE=000000
BACKLOG_FIELD_PAYMENT_PLANNED_DATE=000000
BACKLOG_FIELD_PRODUCT_NAME=000000
BACKLOG_FIELD_EDITION=000000
BACKLOG_FIELD_COMPLETION_DATE=000000
BACKLOG_FIELD_QUANTITY=000000
BACKLOG_FIELD_MSRP=000000
BACKLOG_FIELD_SAMPLE_QUANTITY=000000
BACKLOG_FIELD_REPORT_PERIOD_START=000000
BACKLOG_FIELD_REPORT_PERIOD_END=000000
BACKLOG_FIELD_NET_SALES=000000
BACKLOG_FIELD_S1_REPORT_DUE=000000
BACKLOG_FIELD_S1_PAYMENT_DUE=000000

# --- Google Drive / GWS ---
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/gws-service-account.json
GOOGLE_DRIVE_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_DRIVE_FOLDER_OPTIONS=
GOOGLE_DRIVE_FOLDER_DEFAULT_KEY=legal
GOOGLE_DRIVE_FOLDER_DEFAULT_LABEL=法務共有

# --- Server / DB ---
PORT=3000
LOG_LEVEL=debug
DATABASE_URL=postgresql://postgres:password@localhost:5432/legalbridge
NODE_ENV=development

# --- Document numbering ---
DOCUMENT_DEFAULT_COMPANY_CODE=ARC
DOCUMENT_DEFAULT_DEPARTMENT_CODE=GEN
DOCUMENT_DEPARTMENT_CODE_MAP=法務部:LGL,営業部:SAL,開発部:DEV,制作部:CRT,商品部:PRD
