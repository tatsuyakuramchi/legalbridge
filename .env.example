BACKLOG_FIELD_VENDOR_ACCEPT_NAME=000069      # 相手方承諾者名
BACKLOG_FIELD_VENDOR_CODE=000071             # Vendorマスタ参照用コード

# --- 変更申請コマンド設定 ---
SLACK_CHANGE_CHANNEL=C0000000000             # 変更申請通知チャンネル

