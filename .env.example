# ============================================================
# LegalBridge プロトタイプ 環境変数設定
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# --- Slack ---
# Slack App の設定画面 (api.slack.com/apps) から取得
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx          # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-x-xxxxxxxxxxxx        # App-Level Token (Socket Mode用, connections:write スコープ必要)
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxx      # Signing Secret

# 通知先チャンネルID（法務内部通知用）
SLACK_LEGAL_CHANNEL=C0000000000
APPROVER_SLACK_ID=U0000000000            # 法務責任者のSlackユーザーID
STAMP_OPERATOR_SLACK_ID=U0000000000      # 押印担当者のSlackユーザーID

# --- Backlog ---
# https://your-space.backlog.com/EditApiSettings.action から取得
BACKLOG_API_KEY=HUlVeCDDPqE6mt5x80WuitKKFYbFckfjXwG0TpYodYMaPn4NvN1IHuFeXWocUpvI
BACKLOG_SPACE=arclight                   # スペースID (URLの your-space.backlog.com の部分)
BACKLOG_PROJECT_KEY=LEGAL                  # 法務プロジェクトのキー
BACKLOG_POLLING_INTERVAL_SEC=30           # Backlogポーリング間隔（秒）

# ステータス名（Backlogプロジェクト設定に合わせる）
BACKLOG_STATUS_DOCUMENT_REQUESTED=文書生成依頼
BACKLOG_STATUS_DRAFT=草案
BACKLOG_STATUS_REVIEW=草案
BACKLOG_STATUS_APPROVAL_PENDING=承認待ち
BACKLOG_STATUS_COUNTERPARTY_PENDING=相手方確認待ち
BACKLOG_STATUS_STAMP_PENDING=押印依頼中
BACKLOG_STATUS_SIGNED=締結済
BACKLOG_STATUS_COMPLETED=完了
BACKLOG_STATUS_DISCARDED=破棄
BACKLOG_STATUS_DELIVERY_COMPLETED=処理済み
BACKLOG_ORDER_DUE_ALERT_EXCLUDED_STATUSES=完了,破棄,締結済

# Backlog カスタム属性ID（Backlogの課題設定画面で確認）
BACKLOG_FIELD_REQUESTER=000001             # 依頼部署
BACKLOG_FIELD_CONTRACT_TYPE=000002        # 契約種別
BACKLOG_FIELD_COUNTERPARTY=000003         # 相手方
BACKLOG_FIELD_DEADLINE=000004             # 希望完了日

# Webhookシークレット（Backlogの設定でWebhookを有効化する際に設定）
BACKLOG_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# --- Google Drive (GWS) ---
# サービスアカウントのJSON鍵ファイルパス
# GCP Console でサービスアカウント作成 → キーをJSON形式でダウンロード
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/gws-service-account.json

# 文書保管先のGoogle DriveフォルダID
# DriveでフォルダURLを開いて末尾のID部分をコピー
GOOGLE_DRIVE_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slackモーダルで選ばせる保存先候補
# 例:
# GOOGLE_DRIVE_FOLDER_OPTIONS=[{"key":"legal","label":"法務共有","folderId":"xxxx"},{"key":"license","label":"ライセンス共有","folderId":"yyyy"},{"key":"outsourcing","label":"業務委託共有","folderId":"zzzz"},{"key":"sales","label":"売買契約書共有","folderId":"wwww"}]
GOOGLE_DRIVE_FOLDER_OPTIONS=
GOOGLE_DRIVE_FOLDER_DEFAULT_KEY=legal
GOOGLE_DRIVE_FOLDER_DEFAULT_LABEL=法務共有

# --- サーバー設定 ---
PORT=3000

# --- ログレベル ---
LOG_LEVEL=debug

# --- Backlog カスタムフィールドID（追加分）---
# 発注・支払・検収条件フィールド
BACKLOG_FIELD_ORDER_AMOUNT=000005         # 発注金額（税抜）
BACKLOG_FIELD_TAX_RATE=000006            # 消費税率（例: 10）
BACKLOG_FIELD_DELIVERY_DATE=000007       # 納品予定日 (YYYY-MM-DD)
BACKLOG_FIELD_DESCRIPTION=000008         # 業務内容・品目
BACKLOG_FIELD_CLOSING_TYPE=000009        # 締め方式: monthly or half_monthly
BACKLOG_FIELD_CLOSING_DAY=000010         # 締め日: 末日 or 15 or 20 等
BACKLOG_FIELD_PAYMENT_OFFSET=000011      # 支払月オフセット: 1=翌月, 2=翌々月
BACKLOG_FIELD_PAYMENT_DAY=000012         # 支払日: 末日 or 25 等
BACKLOG_FIELD_INSPECTION_DAYS=000013     # 検収期間（日数）: 7 等

# --- 課題タイプ名（Backlogの設定に合わせる）---
BACKLOG_ISSUE_TYPE_NDA=NDA
BACKLOG_ISSUE_TYPE_OUTSOURCING=業務委託基本契約
BACKLOG_ISSUE_TYPE_LICENSE=ライセンス契約
BACKLOG_ISSUE_TYPE_LICENSE_SCHEDULE=個別利用許諾条件
BACKLOG_ISSUE_TYPE_IP_OVERSEAS_MASTER=海外IP契約（基本契約）
BACKLOG_ISSUE_TYPE_IP_OVERSEAS_AMENDMENT=海外IP契約（変更合意）
BACKLOG_ISSUE_TYPE_SALES_BUYER=売買契約（当社買手）
BACKLOG_ISSUE_TYPE_SALES_SELLER_STANDARD=売買契約（当社売手・標準）
BACKLOG_ISSUE_TYPE_SALES_SELLER_CREDIT=売買契約（当社売手・保証金掛け売り）
BACKLOG_ISSUE_TYPE_PURCHASE_ORDER=発注書
BACKLOG_ISSUE_TYPE_PLANNING_ORDER=企画発注書
BACKLOG_ISSUE_TYPE_PUBLISHING_ORDER=出版発注書
BACKLOG_ISSUE_TYPE_DELIVERY=納品リクエスト
BACKLOG_ISSUE_TYPE_MFG=製造案件

# --- ライセンス契約課題のカスタムフィールドID ---
BACKLOG_FIELD_LEDGER_ID=000020           # 台帳ID (例: LIC-ARC-DOM-202604001)
BACKLOG_FIELD_LICENSOR=000021            # ライセンサー名
BACKLOG_FIELD_LICENSEE=000022            # ライセンシー名（省略時: 株式会社アークライト）
BACKLOG_FIELD_ORIGINAL_WORK=000023       # 原著作物名
BACKLOG_FIELD_CALC_TYPE=000024           # 計算タイプ: manufacturing / sales / sublicense / fixed
BACKLOG_FIELD_ROYALTY_RATE=000025        # ロイヤリティ料率 (例: 0.08 = 8%)
BACKLOG_FIELD_DISTRIBUTION_RATE=000026   # サブライセンス分配率 (例: 0.5 = 50%)
BACKLOG_FIELD_MG_AMOUNT=000027           # MG総額（最低保証金）(例: 500000)
BACKLOG_FIELD_MG_CONSUMED=000028         # MG消化累積額（自動更新）
BACKLOG_FIELD_PAYMENT_CYCLE=000029       # 支払サイクル: event / monthly / quarterly / semi_annual / annual
BACKLOG_FIELD_REPORT_DAYS=000030         # 報告期限（イベント後日数）(例: 30)
BACKLOG_FIELD_PAYMENT_DAYS=000031        # 支払期限（報告後日数）(例: 30)
BACKLOG_FIELD_CURRENCY=000032            # 通貨 (例: JPY)

# --- 製造案件課題のカスタムフィールドID ---
BACKLOG_FIELD_LICENSE_KEY=000040         # 紐付けライセンス課題キー (例: LEGAL-10)
BACKLOG_FIELD_PRODUCT_NAME=000041        # 製品名
BACKLOG_FIELD_EDITION=000042             # 版 (例: 第3刷)
BACKLOG_FIELD_COMPLETION_DATE=000043     # 製造完了日 (YYYY-MM-DD)
BACKLOG_ISSUE_TYPE_LEGAL_CONSULTATION=法務相談
BACKLOG_FIELD_QUANTITY=000044            # 製造数量
BACKLOG_FIELD_MSRP=000045               # MSRP（希望小売価格・税抜）
BACKLOG_FIELD_SAMPLE_QUANTITY=000046     # 販促サンプル数（計算対象外）
BACKLOG_FIELD_MFG_NOTES=000047           # 備考

# --- データベース ---
# ローカル開発時（PostgreSQL をローカルにインストールした場合）
DATABASE_URL=postgresql://postgres:password@localhost:5432/legalbridge

# AWS RDS本番時（移行時にこちらに切り替えるだけ）
# DATABASE_URL=postgresql://dbuser:dbpass@xxx.rds.amazonaws.com:5432/legalbridge

# --- 環境識別 ---
NODE_ENV=development   # production に変更するとSQLログが抑制される

# --- 納品リクエスト課題のカスタムフィールドID ---
# 課題タイプ名は上の BACKLOG_ISSUE_TYPE_DELIVERY を使用
BACKLOG_FIELD_PARENT_ISSUE_KEY=000050         # 親課題キー（例: LEGAL-30）
BACKLOG_FIELD_ITEM_NO=000051                  # 明細番号（例: 1）
BACKLOG_FIELD_DELIVERY_NOTE=000052            # 納品備考
BACKLOG_FIELD_DELIVERED_AMOUNT=000053         # 今回納品金額（分割時のみ）
BACKLOG_FIELD_INSPECTION_DATE=000054         # 検収日
BACKLOG_FIELD_PAYMENT_PLANNED_DATE=000055    # 支払予定日
BACKLOG_FIELD_FINAL_DEADLINE=000056          # 納期 / 校了予定

# --- 発注課題の追加カスタムフィールドID ---
BACKLOG_FIELD_ORDER_ITEMS_JSON=000060         # 業務明細JSON（配列形式）
# 入力例:
# [{"no":1,"desc":"イラスト原稿A","amount":100000,"dueDate":"2026-04-30"},
#  {"no":2,"desc":"イラスト原稿B","spec":"B5/300dpi","amount":80000,"dueDate":"2026-05-15"}]
BACKLOG_FIELD_ORDER_DATE=000061              # 発注日
BACKLOG_FIELD_PROJECT_TITLE=000062           # 案件名
BACKLOG_FIELD_MASTER_CONTRACT_REF=000063     # 基本契約参照番号
BACKLOG_FIELD_BANK_INFO=000064               # 振込先情報
BACKLOG_FIELD_PAYMENT_TERMS=000065           # 支払条件
BACKLOG_FIELD_REMARKS=000066                 # 備考
BACKLOG_FIELD_ACCEPT_METHOD=000067           # 検収方法/承諾方法
