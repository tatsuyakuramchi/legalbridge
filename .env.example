DOCUMENT_DEFAULT_COMPANY_CODE=ARC
DOCUMENT_DEFAULT_DEPARTMENT_CODE=GEN
DOCUMENT_DEPARTMENT_CODE_MAP=法務部:LGL,営業部:SAL,開発部:DEV,制作部:CRT,商品部:PRD
